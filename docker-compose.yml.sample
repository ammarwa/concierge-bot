services:
  concierge:
    image: concierge-bot:latest
    container_name: concierge_bot
    restart: always
    environment:
      - DB_PATH=/data/concierge.db
      - DISCORD_TOKEN=your_token_here
      - MOD_CHANNEL_ID=your_moderator_channel_id
    volumes:
      - bot_data:/data

volumes:
  bot_data:
